<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="${postgres.type} Jdbc Test Suite" verbose="2">
    <parameter name="db.type" value="${postgres.type}"/>
    <parameter name="db.database" value="${postgres.database}"/>
    <parameter name="db.port" value="${postgres.port}"/>
    <parameter name="db.user" value="${postgres.user}"/>
    <parameter name="db.pswd" value="${postgres.pswd}"/>
    <parameter name="db.initScript" value="${postgres.initScript}"/>
    <parameter name="db.cpoConfig" value="${postgres.cpoConfig}"/>
    <parameter name="db.url" value="${postgres.url}"/>
    <parameter name="db.image" value="${postgres.image}"/>
    <parameter name="db.blobsupport" value="${postgres.blobsupport}"/>
    <parameter name="db.callsupport" value="${postgres.callsupport}"/>
    <parameter name="db.select4update" value="${postgres.select4update}"/>
    <parameter name="db.millisupport" value="${postgres.millisupport}"/>
    <parameter name="db.xasupport" value="${postgres.xasupport}"/>
    <listeners>
        <listener class-name="org.synchronoss.cpo.jdbc.JdbcSuiteListener"/>
    </listeners>
    <!--
      Test classes are listed explicitly (instead of a package wildcard) so the
      shared-state mutators below can be kept out of the parallel run. A new test
      class must be added to one of the two lists or it will not be run.
      -->
    <test name="${postgres.type} Jdbc Parallel Tests" verbose="2" parallel="classes" thread-count="4">
        <classes>
            <class name="org.synchronoss.cpo.jdbc.ClassJdbcDataSourceInfoPoolTest"/>
            <class name="org.synchronoss.cpo.jdbc.JndiJdbcDataSourceInfoTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.BlobTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.BlobTrxTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.CaseInsensitiveTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.CaseSensitiveTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.ConstructorTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.CriteriaObjectTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.DeleteObjectTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.EntityTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.ExecuteTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.ExecuteTrxTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.ExistObjectTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.InheritanceTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.InsertObjectTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.InterleavedWhereTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.InvalidParameterTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.NativeExpressionTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.OrderByTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.RollbackTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.RollbackTrxTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.UpdateObjectTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.WhereTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.XmlValidationTest"/>
            <class name="org.synchronoss.cpo.jdbc.config.JdbcCpoConfigProcessorTest"/>
            <class name="org.synchronoss.cpo.jdbc.exporter.ExporterTest"/>
            <class name="org.synchronoss.cpo.jdbc.jta.JdbcXaAdapterDelegationTest"/>
            <class name="org.synchronoss.cpo.jdbc.jta.JdbcXaResourceTest"/>
            <class name="org.synchronoss.cpo.jdbc.parser.BoundExpressionParserTest"/>
            <class name="org.synchronoss.cpo.jdbc.transform.TransformTest"/>
        </classes>
    </test>
    <!--
      These classes mutate state shared across test classes (the global meta
      descriptor, or the cached adapter's fetch/batch size) and must run
      single-threaded, after the parallel block.
      -->
    <test name="${postgres.type} Jdbc Serialized Tests" verbose="2">
        <classes>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigBatchTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigRetrieveTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.HotDeployTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.JdbcAdapterBranchTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.RetrieveBeanTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.SelectForUpdateTest"/>
            <class name="org.synchronoss.cpo.jdbc.exporter.JdbcMetaExportTest"/>
        </classes>
    </test>
</suite>
