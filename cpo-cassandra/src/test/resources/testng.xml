<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cassandra Test Suite" verbose="2">
    <parameter name="cassandra.initScript" value="${cassandra.initScript}"/>
    <parameter name="cassandra.cpoConfig" value="${cassandra.cpoConfig}"/>
    <parameter name="cassandra.image" value="${cassandra.image}"/>
    <parameter name="cassandra.contactPoint" value="${cassandra.contactPoint}"/>
    <parameter name="cassandra.keyspace" value="${cassandra.keyspace}"/>
    <parameter name="cassandra.metaXml" value="${cassandra.metaXml}"/>
    <parameter name="cassandra.nativeport" value="${cassandra.nativeport}"/>
    <parameter name="cassandra.storageport" value="${cassandra.storageport}"/>
    <parameter name="cassandra.sslstorageport" value="${cassandra.sslstorageport}"/>
    <parameter name="cassandra.rpcport" value="${cassandra.rpcport}"/>
    <listeners>
        <listener class-name="org.synchronoss.cpo.cassandra.CassandraSuiteListener"/>
    </listeners>
    <!--
      The package wildcard picks up every test class automatically, so a new test
      class runs in this parallel block by default. Classes that mutate shared state
      are subtracted here via method excludes and listed in the serialized test below.
      -->
    <test name="Cassandra Parallel Tests" verbose="2" parallel="classes" thread-count="4">
        <packages>
            <package name="org.synchronoss.cpo.cassandra.*"/>
        </packages>
        <classes>
            <class name="org.synchronoss.cpo.cassandra.HotDeployTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.cassandra.RetrieveBeanTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.cassandra.exporter.CassandraMetaExportTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
        </classes>
    </test>
    <!--
      These classes mutate state shared across test classes (the global meta
      descriptor, or the cached adapter's fetch size) and must run
      single-threaded, after the parallel block. RetrieveBeanTest must stay here
      because ConstructorTest asserts getFetchSize()/getBatchSize() == 100 on the
      same shared default-context adapter that RetrieveBeanTest temporarily mutates.
      -->
    <test name="Cassandra Serialized Tests" verbose="2">
        <classes>
            <class name="org.synchronoss.cpo.cassandra.HotDeployTest"/>
            <class name="org.synchronoss.cpo.cassandra.RetrieveBeanTest"/>
            <class name="org.synchronoss.cpo.cassandra.exporter.CassandraMetaExportTest"/>
        </classes>
    </test>
</suite>
