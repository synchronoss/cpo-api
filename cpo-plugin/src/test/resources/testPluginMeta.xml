<cpoMetaData metaDescriptor="org.synchronoss.cpo.plugin.TestCpoMetaDescriptor" defaultPackageName="" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.synchronoss.org/cpo/CpoMeta.xsd">
    <cpoClass name="org.synchronoss.cpo.plugin.generated.TestBean">
        <cpoAttribute xsi:type="ctAttribute">
            <javaName>id</javaName>
            <javaType>java.lang.String</javaType>
            <dataName>id</dataName>
            <dataType>VARCHAR</dataType>
        </cpoAttribute>
        <cpoAttribute xsi:type="ctAttribute">
            <javaName>name</javaName>
            <javaType>java.lang.String</javaType>
            <dataName>name</dataName>
            <dataType>VARCHAR</dataType>
        </cpoAttribute>
        <cpoAttribute xsi:type="ctAttribute">
            <javaName>age</javaName>
            <javaType>int</javaType>
            <dataName>age</dataName>
            <dataType>INT</dataType>
        </cpoAttribute>
        <cpoFunctionGroup name="createGroup" type="CREATE">
            <cpoFunction name="createFunction">
                <expression>insert into test_bean (id, name, age) values (?,?,?)</expression>
                <cpoArgument xsi:type="ctArgument">
                    <attributeName>id</attributeName>
                </cpoArgument>
                <cpoArgument xsi:type="ctArgument">
                    <attributeName>name</attributeName>
                </cpoArgument>
                <cpoArgument xsi:type="ctArgument">
                    <attributeName>age</attributeName>
                </cpoArgument>
            </cpoFunction>
        </cpoFunctionGroup>
        <cpoFunctionGroup name="listGroup" type="LIST">
            <cpoFunction name="listFunction">
                <expression>select id, name, age from test_bean</expression>
            </cpoFunction>
        </cpoFunctionGroup>
    </cpoClass>
</cpoMetaData>
