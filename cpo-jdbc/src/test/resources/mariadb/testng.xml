<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="${mariadb.type} Jdbc Test Suite" verbose="2">
    <parameter name="db.type" value="${mariadb.type}"/>
    <parameter name="db.database" value="${mariadb.database}"/>
    <parameter name="db.port" value="${mariadb.port}"/>
    <parameter name="db.user" value="${mariadb.user}"/>
    <parameter name="db.pswd" value="${mariadb.pswd}"/>
    <parameter name="db.initScript" value="${mariadb.initScript}"/>
    <parameter name="db.cpoConfig" value="${mariadb.cpoConfig}"/>
    <parameter name="db.url" value="${mariadb.url}"/>
    <parameter name="db.image" value="${mariadb.image}"/>
    <parameter name="db.blobsupport" value="${mariadb.blobsupport}"/>
    <parameter name="db.callsupport" value="${mariadb.callsupport}"/>
    <parameter name="db.select4update" value="${mariadb.select4update}"/>
    <parameter name="db.millisupport" value="${mariadb.millisupport}"/>
    <parameter name="db.xasupport" value="${mariadb.xasupport}"/>
    <listeners>
        <listener class-name="org.synchronoss.cpo.jdbc.JdbcSuiteListener"/>
    </listeners>
    <!--
      The package wildcard picks up every test class automatically, so a new test
      class runs in this parallel block by default. Classes that mutate shared state
      are subtracted here via method excludes and listed in the serialized test below.
      -->
    <test name="${mariadb.type} Jdbc Parallel Tests" verbose="2" parallel="classes" thread-count="4">
        <packages>
            <package name="org.synchronoss.cpo.jdbc.*"/>
        </packages>
        <classes>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigBatchTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigRetrieveTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.adapter.HotDeployTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.adapter.JdbcAdapterBranchTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.adapter.RetrieveBeanTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.adapter.SelectForUpdateTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
            <class name="org.synchronoss.cpo.jdbc.exporter.JdbcMetaExportTest"> <!-- runs in the serialized test below -->
                <methods>
                    <exclude name=".*"/>
                </methods>
            </class>
        </classes>
    </test>
    <!--
      These classes mutate state shared across test classes (the global meta
      descriptor, the cached adapter's fetch/batch size, or table-wide select-for-update
      locks) and must run single-threaded, after the parallel block. Note that the
      fetch/batch size mutators (RetrieveBeanTest, Big*Test) cannot run parallel even
      though ConstructorTest asserts sizes on differently-named contexts: adapters are
      cached by metaDescriptor + dataSourceName, so the jdbc/class/classProp contexts
      all share one adapter instance.
      -->
    <test name="${mariadb.type} Jdbc Serialized Tests" verbose="2">
        <classes>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigBatchTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.BigRetrieveTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.HotDeployTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.JdbcAdapterBranchTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.RetrieveBeanTest"/>
            <class name="org.synchronoss.cpo.jdbc.adapter.SelectForUpdateTest"/>
            <class name="org.synchronoss.cpo.jdbc.exporter.JdbcMetaExportTest"/>
        </classes>
    </test>
</suite>
